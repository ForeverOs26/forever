SUPABASE_PROJECT_ID=your-supabase-project-id
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Forever Studio (server-side only — NEVER exposed to the browser bundle):
# The Studio server boundary verifies the signed-in publisher's token with
# SUPABASE_URL + SUPABASE_PUBLISHABLE_KEY (already set above) and performs
# writes with SUPABASE_SERVICE_ROLE_KEY (server process only). The one-time
# Owner bootstrap is single-winner in the database and matches EITHER a stable
# user id (preferred) OR a confirmed email; it only fires while the
# studio_members roster is empty, and every other account stays locked out
# until invited.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# STUDIO_OWNER_USER_ID=your-supabase-auth-user-id
# STUDIO_OWNER_EMAIL=owner@example.com

# Optional local development safety mode (ignored by production builds):
# ordinary `npm run dev` keeps the existing lead-write behavior. Set this to
# "true" when you deliberately want forms to validate and complete without a
# network request or saved lead. The Partner Demo launcher enforces this itself.
# VITE_DEMO_LEAD_MODE=true
