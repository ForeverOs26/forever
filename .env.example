SUPABASE_PROJECT_ID=your-supabase-project-id
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Forever Studio (server-side only — NEVER exposed to the browser bundle):
# SUPABASE_SERVICE_ROLE_KEY is read exclusively by the server process for the
# Studio boundary and owner tooling. STUDIO_OWNER_EMAIL enables the one-time
# Owner bootstrap: when the studio_members roster is empty, a signed-in user
# with exactly this email becomes the Owner; every other account stays locked
# out until invited.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# STUDIO_OWNER_EMAIL=owner@example.com

# Optional local development safety mode (ignored by production builds):
# ordinary `npm run dev` keeps the existing lead-write behavior. Set this to
# "true" when you deliberately want forms to validate and complete without a
# network request or saved lead. The Partner Demo launcher enforces this itself.
# VITE_DEMO_LEAD_MODE=true
